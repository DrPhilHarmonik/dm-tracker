/* ---- Global ---- */
Screen {
    background: #1a1a2e;
}

Header {
    background: #16213e;
    color: #e0e0e0;
}

Footer {
    background: #16213e;
}

Button {
    margin: 0 1 0 0;
    min-width: 14;
}

Input, Select {
    margin-bottom: 1;
}

Label {
    color: #b2ccd6;
}

.action-row {
    height: auto;
    align: left middle;
}

#actions,
#detail-actions,
#form-actions,
#rel-actions,
#sheet-actions,
#wizard-actions,
#pending-rel-actions,
#attack-actions,
#special-actions,
#wiz-attack-actions,
#wiz-special-actions,
#initiative-actions,
#hp-actions,
#turn-advance-actions,
#roll-ability-actions,
#roll-attack-actions,
#attack-roll-actions,
#export-actions,
#delrel-actions {
    height: auto;
    align: left middle;
}

#backup-status,
#restore-status,
#vault-import-status,
#export-status,
#wizard-error,
#roll-result {
    min-height: 1;
}

/* ---- Dashboard ---- */
#dashboard {
    padding: 2 4;
    height: 1fr;
}

#title {
    text-align: center;
    color: #c792ea;
    text-style: bold;
    margin-bottom: 2;
    padding: 1;
    border: solid #c792ea;
}

#cards {
    layout: grid;
    grid-size: 3 3;
    grid-gutter: 1 2;
    height: auto;
    margin-bottom: 2;
}

.card {
    height: 5;
    content-align: center middle;
    background: #16213e;
    border: solid #0f3460;
    text-align: center;
}

.card:hover {
    background: #0f3460;
}

#actions {
    align: center middle;
    height: auto;
}

#actions Button {
    min-width: 20;
}

/* ---- Entity List ---- */
#list-container {
    height: 1fr;
    padding: 1 2;
}

#list-toolbar {
    height: auto;
    margin-bottom: 1;
    align: left middle;
}

#list-toolbar Input {
    width: 1fr;
    margin-right: 1;
}

#list-toolbar Button {
    min-width: 18;
}

DataTable {
    height: 1fr;
    background: #16213e;
}

/* ---- Entity Detail ---- */
#detail-scroll {
    height: 1fr;
    padding: 1 2;
    background: #16213e;
}

#detail-actions {
    height: auto;
    padding: 1 2;
    align: left middle;
    background: #1a1a2e;
}

#detail-actions Button {
    min-width: 16;
}

/* ---- Entity Form ---- */
#form-scroll {
    height: 1fr;
    padding: 1 2;
}

#form-fields {
    height: auto;
}

#form-fields Label {
    margin-top: 1;
}

#form-fields Input {
    width: 1fr;
}

#form-fields Select {
    width: 1fr;
}

#form-fields TextArea {
    height: 10;
    width: 1fr;
}

#pending-rel-actions {
    margin-top: 1;
}

#form-fields ListView {
    height: 6;
    margin-top: 1;
    background: #1a1a2e;
    border: solid #0f3460;
}

#form-actions {
    padding: 1 2;
    background: #1a1a2e;
}

/* ---- Relationship Form ---- */
#rel-scroll {
    height: 1fr;
    padding: 1 2;
}

#rel-form {
    height: auto;
}

#rel-form Label {
    margin-top: 1;
}

#rel-form Select {
    width: 1fr;
}

#rel-form Input {
    width: 1fr;
}

#rel-actions {
    padding: 1 2;
}

/* ---- Delete Rel ---- */
#delrel-container {
    padding: 1 2;
    height: 1fr;
}

#delrel-container ListView {
    height: 1fr;
    margin: 1 0;
    background: #1a1a2e;
    border: solid #0f3460;
}

#delrel-actions Button {
    min-width: 18;
}

/* ---- Confirm Modal ---- */
#confirm-box {
    width: 50;
    height: auto;
    padding: 2;
    background: #16213e;
    border: solid #c792ea;
    align: center middle;
}


#confirm-box Static {
    margin-bottom: 1;
    text-align: center;
}

#confirm-box Horizontal {
    height: auto;
    align: center middle;
}

ConfirmScreen {
    align: center middle;
    background: rgba(0,0,0,0.7);
}

/* ---- Export ---- */
#export-container {
    padding: 2 4;
    height: 1fr;
}

#export-title {
    text-style: bold;
    color: #c3e88d;
    margin-bottom: 2;
}

#export-container Label {
    margin-top: 1;
}

#export-container Input {
    width: 1fr;
}

#export-status {
    margin-top: 1;
}

#export-actions {
    margin-top: 1;
}

#export-actions Button {
    min-width: 16;
}

#export-stats-row {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#export-stats-row Label {
    margin-top: 0;
    margin-left: 1;
}

/* ---- Global Search ---- */
#global-search-container {
    padding: 1 2;
    height: 1fr;
}

#global-search-container Input {
    margin-bottom: 1;
}

/* ---- Backup / Restore ---- */
#backup-scroll {
    height: 1fr;
}

#backup-container {
    padding: 2 4;
    height: auto;
}

#backup-title, #vault-import-title {
    text-style: bold;
    color: #f78c6c;
    margin-bottom: 2;
}

#vault-import-title {
    margin-top: 2;
}

#backup-container Label {
    margin-top: 1;
}

#backup-container Input {
    width: 1fr;
}

#backup-status, #restore-status, #vault-import-status {
    margin: 1 0;
}

/* ---- Character Sheet ---- */
#sheet-tabs {
    height: 1fr;
}

#abilities-scroll, #combat-scroll, #skills-scroll, #attacks-scroll {
    height: 1fr;
    padding: 1 2;
}

#abilities-fields, #combat-fields, #skills-fields, #attacks-fields {
    height: auto;
}

.ability-row, .save-row, .skill-row {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

.ability-label {
    width: 16;
}

.ability-input {
    width: 8;
    margin-right: 2;
}

.ability-mod {
    width: 6;
    color: #c3e88d;
    text-style: bold;
}

.save-label, .skill-label {
    width: 24;
}

.save-bonus, .skill-bonus {
    width: 6;
    margin-left: 2;
    color: #c3e88d;
    text-style: bold;
}

#combat-fields Label {
    margin-top: 1;
}

#combat-fields Input {
    width: 1fr;
}

#combat-fields Static#sheet-prof-bonus {
    color: #c3e88d;
    text-style: bold;
}

#combat-fields Input.stat-input,
#form-fields Input.stat-input,
#wizard-step Input.stat-input {
    width: 14;
}

#attack-inputs, #special-inputs {
    height: auto;
    margin-top: 1;
}

#attack-inputs Input, #special-inputs Input {
    width: 1fr;
    margin-right: 1;
}

#attack-actions, #special-actions {
    margin-top: 1;
}

#attack-actions Button, #special-actions Button {
    min-width: 20;
}

#attacks-fields ListView {
    height: 6;
    margin-bottom: 1;
    background: #1a1a2e;
    border: solid #0f3460;
}

#attacks-fields Static {
    margin-top: 1;
}

#sheet-actions {
    padding: 1 2;
    background: #1a1a2e;
}

#sheet-actions Button {
    min-width: 18;
}

/* ---- Roll Picker ---- */
#roll-tabs {
    height: 1fr;
}

#roll-ability-scroll, #roll-skill-scroll, #roll-attack-scroll, #roll-custom-scroll {
    height: 1fr;
}

#roll-ability-fields, #roll-skill-fields, #roll-attack-fields, #roll-custom-fields {
    height: auto;
    padding: 1 2;
}

#roll-ability-fields Label, #roll-skill-fields Label, #roll-attack-fields Label, #roll-custom-fields Label {
    margin-top: 1;
}

#roll-ability-fields Select, #roll-skill-fields Select, #roll-attack-fields Select {
    width: 1fr;
}

#roll-custom-fields Input {
    width: 1fr;
}

#roll-ability-mode, #roll-skill-mode, #roll-attack-mode {
    height: auto;
    align: left middle;
    margin-top: 1;
}

#roll-ability-mode Label, #roll-skill-mode Label {
    margin-right: 2;
    margin-top: 0;
}

#roll-ability-actions, #roll-attack-actions {
    margin-top: 1;
}

#roll-ability-actions Button, #roll-attack-actions Button {
    min-width: 20;
}

#roll-output {
    height: auto;
    max-height: 12;
    padding: 1 2;
    background: #16213e;
    border: solid #0f3460;
}

#roll-result {
    margin-bottom: 1;
}

#roll-history {
    height: 8;
    background: #1a1a2e;
    border: solid #0f3460;
}

/* ---- Combat Tracker ---- */
#combat-tabs {
    height: 1fr;
}

#combatants-scroll, #hp-conditions-scroll, #turn-controls-scroll {
    height: 1fr;
}

#combatants-fields, #hp-conditions-fields, #turn-controls-fields {
    height: auto;
    padding: 1 2;
}

#combatants-fields Label, #hp-conditions-fields Label {
    margin-top: 1;
}

#combatants-fields Select, #hp-conditions-fields Select {
    width: 1fr;
}

#combatants-fields Input, #hp-conditions-fields Input {
    width: 1fr;
}

#initiative-actions, #hp-actions, #turn-advance-actions, #attack-roll-actions {
    margin-top: 1;
}

#initiative-actions Button, #hp-actions Button, #turn-advance-actions Button, #attack-roll-actions Button {
    min-width: 18;
}

#attack-roll-mode {
    height: auto;
    align: left middle;
    margin-top: 1;
}

#attack-roll-mode Label {
    margin-top: 0;
    margin-right: 2;
}

#attack-roll-result {
    margin: 1 0;
    color: #c3e88d;
    text-style: bold;
}

#turn-controls-fields Button {
    width: 1fr;
    margin-top: 1;
}

#hp-conditions-fields ListView {
    height: 6;
    margin-top: 1;
    margin-bottom: 1;
    background: #1a1a2e;
    border: solid #0f3460;
}

#combat-summary-scroll {
    height: auto;
    max-height: 14;
    padding: 1 2;
    background: #16213e;
    border: solid #0f3460;
}

/* ---- Active Effects ---- */
#effects-scroll {
    height: 1fr;
    padding: 1 2;
}

#effects-fields {
    height: auto;
}

#effects-fields Label {
    margin-top: 1;
}

#effects-fields Input, #effects-fields Select {
    width: 1fr;
}

#effects-fields ListView {
    height: 8;
    margin-top: 1;
    margin-bottom: 1;
    background: #1a1a2e;
    border: solid #0f3460;
}

/* ---- Session Workflow ---- */
#session-workflow-scroll {
    height: 1fr;
    padding: 1 2;
}

.workflow-heading {
    text-style: bold;
    color: #b2ccd6;
    margin-top: 1;
}

#session-workflow-scroll DataTable {
    height: 6;
    margin-bottom: 1;
}

#wf-pc-actions {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#wf-pc-actions Button {
    min-width: 20;
}

/* ---- Creation Wizard ---- */
#wizard-scroll {
    height: 1fr;
    padding: 1 2;
}

#wizard-step {
    height: auto;
}

#wizard-step Label {
    margin-top: 1;
}

#wizard-step Input, #wizard-step Select {
    width: 1fr;
}

#wizard-step ListView {
    height: 6;
    margin-top: 1;
    margin-bottom: 1;
    background: #1a1a2e;
    border: solid #0f3460;
}

#wiz-attack-inputs Input, #wiz-special-inputs Input {
    width: 1fr;
    margin-right: 1;
}

#wiz-attack-actions, #wiz-special-actions {
    margin-top: 1;
}

#wiz-attack-actions Button, #wiz-special-actions Button {
    min-width: 20;
}

#wiz-review-summary {
    margin: 1 0;
    background: #16213e;
    border: solid #0f3460;
    padding: 1 2;
}

#wizard-actions {
    padding: 1 2;
    background: #1a1a2e;
}

#wizard-error {
    color: #ff5370;
    margin-bottom: 1;
}

#wizard-nav {
    height: auto;
}

#wizard-nav Button {
    min-width: 18;
}
